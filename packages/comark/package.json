{
  "name": "comark",
  "type": "module",
  "version": "0.3.1",
  "description": "Components in Markdown (Comark) parser with streaming support for Vue, React, Svelte and HTML",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comarkdown/comark.git"
  },
  "bugs": {
    "url": "https://github.com/comarkdown/comark/issues"
  },
  "homepage": "https://comark.dev",
  "keywords": [
    "markdown",
    "mdc",
    "parser",
    "streaming",
    "vue",
    "react"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./plugins/*": "./dist/plugins/*.js",
    "./utils": "./dist/utils/index.js",
    "./parse": "./dist/parse.js",
    "./render": "./dist/render.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "node ../../scripts/stub.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepack": "tsc",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "peerDependencies": {
    "beautiful-mermaid": "catalog:",
    "katex": "catalog:",
    "shiki": "catalog:"
  },
  "peerDependenciesMeta": {
    "shiki": {
      "optional": true
    },
    "beautiful-mermaid": {
      "optional": true
    },
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@json-render/core": "catalog:",
    "@shikijs/twoslash": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/markdown-it": "catalog:",
    "github-slugger": "catalog:",
    "hast-util-to-string": "catalog:",
    "minimark": "catalog:",
    "tsx": "catalog:",
    "twoslash": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@comark/markdown-it": "catalog:",
    "entities": "catalog:",
    "htmlparser2": "catalog:",
    "js-yaml": "catalog:",
    "markdown-exit": "catalog:"
  }
}
