{
  "name": "@comark/html",
  "type": "module",
  "version": "0.2.1",
  "description": "HTML renderer for Comark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comarkdown/comark.git"
  },
  "bugs": {
    "url": "https://github.com/comarkdown/comark/issues"
  },
  "homepage": "https://comark.dev/rendering/html",
  "exports": {
    ".": "./dist/index.js",
    "./plugins/*": "./dist/plugins/*.js",
    "./utils": "./dist/utils/index.js",
    "./parse": "./dist/parse.js",
    "./render": "./dist/render.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "node ../../scripts/stub.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepack": "tsc",
    "release": "release-it"
  },
  "dependencies": {
    "comark": "^0.2.1"
  },
  "peerDependencies": {
    "katex": ">=0.16",
    "beautiful-mermaid": ">=1.0",
    "shiki": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    },
    "beautiful-mermaid": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "katex": "^0.16.45",
    "beautiful-mermaid": "^1.1.3",
    "vitest": "^4.1.4"
  }
}
