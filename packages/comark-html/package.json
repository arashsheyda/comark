{
  "name": "@comark/html",
  "type": "module",
  "version": "0.0.1",
  "description": "HTML renderer for Comark",
  "exports": {
    ".": "./dist/index.js",
    "./plugins/*": "./dist/plugins/*.js",
    "./utils": "./dist/utils/index.js",
    "./parse": "./dist/parse.js",
    "./render": "./dist/render.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "node ../../scripts/stub.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepack": "tsc"
  },
  "dependencies": {
    "comark": "^1.0.0"
  },
  "peerDependencies": {
    "katex": ">=0.16",
    "beautiful-mermaid": ">=1.0",
    "shiki": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "katex": { "optional": true },
    "beautiful-mermaid": { "optional": true },
    "shiki": { "optional": true }
  },
  "devDependencies": {
    "comark": "workspace:*",
    "katex": "^0.16.0",
    "beautiful-mermaid": "^1.1.3",
    "vitest": "^4.0.18"
  }
}
