{
  "name": "@comark/nuxt",
  "type": "module",
  "version": "0.2.0",
  "description": "Nuxt module for Comark",
  "exports": {
    ".": "./dist/module.js",
    "./plugins/*": "./dist/plugins/*.js",
    "./utils": "./dist/utils/index.js",
    "./parse": "./dist/parse.js",
    "./render": "./dist/render.js"
  },
  "main": "./dist/module.js",
  "module": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "node ../../scripts/stub.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "prepack": "tsc",
    "release": "release-it"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0"
  },
  "dependencies": {
    "comark": "^0.2.0",
    "@comark/vue": "^0.2.0",
    "@nuxt/kit": "^4.4.2"
  },
  "devDependencies": {
    "@vue/server-renderer": "^3.5.32",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  }
}
