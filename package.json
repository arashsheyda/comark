{
  "name": "comark-monorepo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Comark monorepo",
  "author": "",
  "license": "MIT",
  "repository": "comarkdown/comark",
  "scripts": {
    "dev": "pnpm dev:vue",
    "dev:playground": "nuxt dev playground",
    "dev:prepare": "nuxt prepare playground",
    "dev:html": "pnpm --filter comark-html run dev",
    "dev:react": "pnpm --filter comark-react run dev",
    "dev:svelte": "pnpm --filter comark-svelte run dev",
    "dev:ansi": "pnpm --filter comark-ansi run dev",
    "dev:vue": "pnpm --filter comark-vue run dev",
    "dev:vue:mermaid": "pnpm --filter comark-vue-vite-mermaid run dev",
    "dev:vue:math": "pnpm --filter comark-vue-vite-math run dev",
    "dev:astro": "pnpm --filter comark-astro run dev",
    "dev:vitepress": "pnpm --filter comark-vitepress run dev",
    "dev:nuxt": "pnpm --filter comark-nuxt run dev",
    "dev:nextjs": "pnpm --filter comark-nextjs run dev",
    "dev:highlight": "pnpm --filter comark-vue-vite-highlight run dev",
    "dev:twoslash": "pnpm --filter comark-vue-vite-twoslash run dev",
    "dev:json-render": "pnpm --filter comark-vue-vite-json-render run dev",
    "dev:binding": "pnpm --filter comark-vue-vite-binding run dev",
    "docs": "nuxt dev --extends docus docs",
    "prepack": "pnpm build && pnpm sync-plugins",
    "stub": "pnpm --parallel --filter './packages/**' run stub && pnpm sync-plugins",
    "sync-plugins": "node scripts/sync-plugins.mjs",
    "dev:packages": "pnpm --parallel --filter './packages/**' run dev",
    "build": "pnpm build:comark && pnpm --filter './packages/**' run build && pnpm sync-plugins",
    "build:comark": "cd packages/comark && pnpm build",
    "test": "pnpm --filter 'comark' run test && pnpm --filter '@comark/*' run test",
    "test:spec": "cd packages/comark && pnpm vitest run test/index.test.ts -- -spec",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run lint && pnpm run test && pnpm run typecheck",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry",
    "postinstall": "pnpm stub"
  },
  "devDependencies": {
    "@comark/ansi": "workspace:*",
    "@comark/markdown-it": "catalog:",
    "@nuxt/eslint-config": "catalog:",
    "@release-it/conventional-changelog": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "comark": "workspace:*",
    "eslint": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "markdown-exit": "catalog:",
    "markdown-it": "catalog:",
    "markdown-it-emoji": "^3.0.0",
    "mitata": "catalog:",
    "nuxt": "catalog:",
    "playwright": "catalog:",
    "release-it": "catalog:",
    "remark-gfm": "catalog:",
    "remark-mdc": "catalog:",
    "remark-parse": "catalog:",
    "remark-rehype": "catalog:",
    "remark-smartypants": "^3.0.2",
    "scule": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unified": "catalog:"
  },
  "resolutions": {
    "comark": "workspace:*",
    "@comark/vue": "workspace:*",
    "@comark/react": "workspace:*",
    "@comark/svelte": "workspace:*",
    "@comark/nuxt": "workspace:*",
    "@comark/html": "workspace:*",
    "@comark/ansi": "workspace:*",
    "@unhead/vue": "catalog:",
    "vue": "catalog:",
    "@vue/runtime-core": "catalog:",
    "@vue/runtime-dom": "catalog:",
    "@vue/server-renderer": "catalog:",
    "@vue/compiler-core": "catalog:",
    "@vue/reactivity": "catalog:",
    "@vue/shared": "catalog:"
  }
}
